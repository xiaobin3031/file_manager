{
  "manifest_version": 3,
  "name": "文件管理辅助下载插件",
  "version": "1.0",
  "permissions": ["scripting", "activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://mycomic.com/chapters/*"],
      "js": ["js/dom.js", "js/request.js", "js/mycomic.js" ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://192.168.50.133:6547/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
